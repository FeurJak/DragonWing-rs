# DragonWing-rs Environment Configuration
# Copy this file to .env and fill in your board's credentials
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env && make flash
#
# Or export directly:
#   export BOARD_IP=192.168.1.100
#   export BOARD_USER=arduino
#   export BOARD_PASS=your_password
#   make flash

# Arduino Uno Q board IP address
BOARD_IP=192.168.1.100

# SSH username for the board
BOARD_USER=arduino

# SSH password for the board
BOARD_PASS=your_password_here
